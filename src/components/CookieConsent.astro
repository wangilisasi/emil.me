---
const consentKey = "emil-cookie-consent";
---

<div
  id="cookie-consent"
  class="fixed right-4 bottom-4 left-4 z-50 mx-auto hidden max-w-3xl rounded-lg border border-border bg-background/95 p-4 text-sm shadow-lg backdrop-blur sm:right-6 sm:bottom-6 sm:left-auto sm:max-w-md"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie consent"
  data-consent-key={consentKey}
>
  <p class="leading-relaxed">
    I use a little browser storage to remember preferences and optional
    privacy-friendly analytics. You can accept or reject it.
  </p>
  <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:justify-end">
    <button
      type="button"
      id="cookie-consent-reject"
      class="rounded-md border border-border px-4 py-2 font-semibold transition-colors hover:text-accent"
    >
      Reject
    </button>
    <button
      type="button"
      id="cookie-consent-accept"
      class="rounded-md bg-accent px-4 py-2 font-semibold text-background transition-opacity hover:opacity-90"
    >
      Accept
    </button>
  </div>
</div>

<script>
  const CONSENT_ACCEPTED = "accepted";
  const CONSENT_REJECTED = "rejected";
  const PRIVACY_REGION_ENDPOINT = "/api/privacy-region";

  async function requiresCookieConsent() {
    try {
      const response = await fetch(PRIVACY_REGION_ENDPOINT, {
        cache: "no-store",
        headers: { accept: "application/json" },
      });

      if (!response.ok) return true;

      const region = await response.json();
      return region.requiresConsent === true;
    } catch {
      return true;
    }
  }

  function getStoredConsent(consentKey: string) {
    try {
      return localStorage.getItem(consentKey);
    } catch {
      return null;
    }
  }

  function setStoredConsent(consentKey: string, consent: string) {
    try {
      localStorage.setItem(consentKey, consent);
    } catch {
      // If storage is unavailable, keep the choice for this page only.
    }
  }

  function sendConsentEvent(consent: string) {
    window.dispatchEvent(
      new CustomEvent("cookie-consent", { detail: { consent } }),
    );
  }

  function hideCookieConsent(banner: HTMLElement) {
    banner.classList.add("hidden");
  }

  async function initCookieConsent() {
    const banner = document.querySelector<HTMLElement>("#cookie-consent");
    if (!banner || banner.dataset.initialized === "true") return;

    banner.dataset.initialized = "true";

    const consentKey = banner.dataset.consentKey;
    const acceptButton = document.querySelector<HTMLButtonElement>(
      "#cookie-consent-accept",
    );
    const rejectButton = document.querySelector<HTMLButtonElement>(
      "#cookie-consent-reject",
    );

    if (!consentKey || !acceptButton || !rejectButton) return;

    const storedConsent = getStoredConsent(consentKey);
    if (storedConsent === CONSENT_ACCEPTED || storedConsent === CONSENT_REJECTED) {
      hideCookieConsent(banner);
      return;
    }

    const consentRequired = await requiresCookieConsent();
    if (!consentRequired) {
      hideCookieConsent(banner);
      return;
    }

    banner.classList.remove("hidden");

    acceptButton.addEventListener("click", () => {
      setStoredConsent(consentKey, CONSENT_ACCEPTED);
      hideCookieConsent(banner);
      sendConsentEvent(CONSENT_ACCEPTED);
    });

    rejectButton.addEventListener("click", () => {
      setStoredConsent(consentKey, CONSENT_REJECTED);
      hideCookieConsent(banner);
      sendConsentEvent(CONSENT_REJECTED);
    });
  }

  initCookieConsent();
  document.addEventListener("astro:page-load", initCookieConsent);
</script>
